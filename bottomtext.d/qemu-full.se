PACKAGES=( 
    qemu-kvm 
    libvirt 
    ublue-os-libvirt-workarounds
    genisoimage 
    libvirt-nss 
    virt-v2v 
    qemu-char-spice 
)

ASSOCIATE_GROUPS=( "jumpyvi libvirt" )

ADOPT_ETC=yes
# You can also run manual fixes in /etc if ADOPT_ETC is enabled
mkdir -p /etc/ld.so.conf.d
echo "/usr/lib64/iscsi" > /etc/ld.so.conf.d/iscsi-libvirt.conf


# You have to reboot for this one
